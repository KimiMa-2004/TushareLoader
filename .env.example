# Tushare Pro token (required). Get from https://tushare.pro/register
# Copy this file to .env and set your token.
TUSHARE_TOKEN=your_token_here

# Root directory for all output Parquet files.
# Data is saved under {DATAROOT}/{db_name}/{table_name}/
DATAROOT=D:/data/

# Optional: logging
LOG_LEVEL=INFO
LOGGER_DIR=./logs
